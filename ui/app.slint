// NeonPrime UI — Phase 1: live telemetry HUD.
// Two first-class themes driven by `Theme.hev`; live data flows in via `Sys`.

global Theme {
    in-out property <bool> hev: false;

    // Surfaces
    out property <color> bg: hev ? #0d0b06 : #061119;
    out property <color> divider: hev ? #463209 : #123043;
    out property <color> track: hev ? #261b07 : #0e2230;

    // Accents — `accent` reports nominal data, `ember` flags attention / active state.
    out property <color> accent: hev ? #ff9f2e : #34d2ff;
    out property <color> accent-soft: hev ? #ffc061 : #8ae9ff;
    out property <color> ember: hev ? #e24b4a : #ce8a1f;
    out property <color> ember-soft: hev ? #ff7a6a : #e6ae45;

    // Text
    out property <color> text-dim: hev ? #8a6a2a : #5c7e92;
    out property <color> text-body: hev ? #c9a766 : #a9c6d6;

    // Theme-dependent copy
    out property <string> overview-title: hev ? "HAZARD SYSTEMS ONLINE" : "SYSTEM OVERVIEW";
    out property <string> tweaks-label: hev ? "PRY BLOAT" : "TWEAKS";
    out property <string> tagline: hev ? "HEV · v3.0" : "v3.0.0";
    out property <string> toggle-label: hev ? "THEME: HEV" : "THEME: HOLO";
}

// Live system vitals, written each tick from Rust.
export global Sys {
    in-out property <float> cpu-ratio: 0;
    in-out property <string> cpu-text: "—";
    in-out property <float> ram-ratio: 0;
    in-out property <string> ram-text: "—";
    in-out property <bool> gpu-available: false;
    in-out property <float> gpu-ratio: 0;
    in-out property <string> gpu-text: "—";
    in-out property <float> vram-ratio: 0;
    in-out property <string> vram-text: "—";
    in-out property <float> temp-ratio: 0;
    in-out property <string> temp-text: "—";
    in-out property <bool> temp-warn: false;
}

component NavItem inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    in property <image> icon;
    height: 34px;
    background: active ? Theme.accent.with-alpha(0.08) : transparent;

    Rectangle {
        x: 0;
        y: 0;
        width: 3px;
        height: parent.height;
        background: active ? Theme.accent : transparent;
    }
    HorizontalLayout {
        padding-left: 16px;
        spacing: 12px;
        alignment: start;
        VerticalLayout {
            alignment: center;
            Image {
                width: 20px;
                height: 20px;
                source: root.icon;
                colorize: root.active ? Theme.accent : Theme.text-dim;
            }
        }
        Text {
            text: root.label;
            color: active ? Theme.accent-soft : Theme.text-dim;
            vertical-alignment: center;
            font-size: 12px;
        }
    }
}

component ModePill inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    width: 58px;
    height: 26px;
    border-radius: 8px;
    border-width: 1px;
    border-color: active ? Theme.accent : Theme.divider;
    background: active ? Theme.accent.with-alpha(0.16) : transparent;
    Text {
        text: root.label;
        color: active ? Theme.accent-soft : Theme.text-dim;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 11px;
    }
}

component Meter inherits VerticalLayout {
    in property <string> label;
    in property <string> value;
    in property <float> ratio;
    in property <bool> warn;
    spacing: 6px;

    HorizontalLayout {
        Text {
            text: root.label;
            color: Theme.text-dim;
            font-size: 11px;
        }
        Rectangle { horizontal-stretch: 1; }
        Text {
            text: root.value;
            color: root.warn ? Theme.ember-soft : Theme.accent;
            font-size: 11px;
        }
    }
    Rectangle {
        height: 10px;
        border-radius: 5px;
        background: Theme.track;
        Rectangle {
            x: 0;
            y: 0;
            width: parent.width * clamp(root.ratio, 0, 1);
            height: parent.height;
            border-radius: 5px;
            background: root.warn ? Theme.ember : Theme.accent;
        }
    }
}

// Circular load gauge. The value arc is an SVG arc computed from `ratio`.
component Gauge inherits Rectangle {
    in property <float> ratio;
    in property <string> value-text;
    in property <string> caption;
    in property <bool> warn;
    width: 132px;
    height: 132px;

    // Geometry in a 124x124 box: centre (62,62), radius 58, sweep from the top.
    property <float> r: clamp(root.ratio, 0, 0.9999);
    property <angle> end-ang: -90deg + r * 359.9deg;
    property <float> ex: 62 + 58 * cos(end-ang);
    property <float> ey: 62 + 58 * sin(end-ang);
    property <int> large: r * 359.9 > 180 ? 1 : 0;

    Rectangle {
        x: 4px;
        y: 4px;
        width: 124px;
        height: 124px;
        border-radius: 62px;
        border-width: 8px;
        border-color: Theme.track;
        background: transparent;
    }
    Path {
        x: 4px;
        y: 4px;
        width: 124px;
        height: 124px;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: 124;
        viewbox-height: 124;
        commands: "M 62 4 A 58 58 0 \{root.large} 1 \{root.ex} \{root.ey}";
        stroke: root.warn ? Theme.ember : Theme.accent;
        stroke-width: 7px;
        fill: transparent;
    }
    VerticalLayout {
        alignment: center;
        spacing: 2px;
        Text {
            text: root.value-text;
            color: root.warn ? Theme.ember-soft : Theme.accent-soft;
            horizontal-alignment: center;
            font-size: 30px;
        }
        Text {
            text: root.caption;
            color: Theme.text-dim;
            horizontal-alignment: center;
            font-size: 11px;
        }
    }
}

export component AppWindow inherits Window {
    title: "NeonPrime";
    default-font-size: 13px;
    preferred-width: 720px;
    preferred-height: 500px;
    min-width: 620px;
    min-height: 440px;
    background: Theme.bg;

    VerticalLayout {
        // ── Title bar ──────────────────────────────────────────────
        Rectangle {
            height: 44px;
            HorizontalLayout {
                padding-left: 20px;
                padding-right: 14px;
                spacing: 12px;
                alignment: start;
                VerticalLayout {
                    alignment: center;
                    Image {
                        width: 20px;
                        height: 20px;
                        source: Theme.hev ? @image-url("icons/lambda.svg") : @image-url("icons/logo.svg");
                        colorize: Theme.accent-soft;
                    }
                }
                VerticalLayout {
                    alignment: center;
                    Text {
                        text: "NEONPRIME";
                        color: Theme.accent-soft;
                        font-size: 16px;
                    }
                }
                VerticalLayout {
                    alignment: center;
                    Text {
                        text: Theme.tagline;
                        color: Theme.text-dim;
                        font-size: 11px;
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                Rectangle {
                    width: 112px;
                    height: 26px;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: Theme.divider;
                    background: Theme.accent.with-alpha(0.08);
                    Text {
                        text: Theme.toggle-label;
                        color: Theme.accent-soft;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: 11px;
                    }
                    TouchArea {
                        clicked => {
                            Theme.hev = !Theme.hev;
                        }
                    }
                }
            }
            Rectangle {
                x: 0;
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: Theme.divider;
            }
        }

        // ── Body ───────────────────────────────────────────────────
        HorizontalLayout {
            // Sidebar
            Rectangle {
                width: 160px;
                VerticalLayout {
                    padding-top: 26px;
                    padding-bottom: 16px;
                    spacing: 4px;
                    NavItem {
                        label: "DASHBOARD";
                        active: true;
                        icon: @image-url("icons/dashboard.svg");
                    }
                    NavItem {
                        label: Theme.tweaks-label;
                        icon: Theme.hev ? @image-url("icons/crowbar.svg") : @image-url("icons/tweaks.svg");
                    }
                    NavItem {
                        label: "INSTALL";
                        icon: @image-url("icons/install.svg");
                    }
                    NavItem {
                        label: "MODES";
                        icon: @image-url("icons/modes.svg");
                    }
                    NavItem {
                        label: "CONFIG";
                        icon: @image-url("icons/config.svg");
                    }
                    Rectangle { vertical-stretch: 1; }
                    HorizontalLayout {
                        padding-left: 18px;
                        spacing: 10px;
                        alignment: start;
                        Rectangle {
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            background: Theme.accent;
                        }
                        Text {
                            text: "BROKER · linked";
                            color: Theme.text-dim;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                    }
                }
                Rectangle {
                    x: parent.width - 1px;
                    y: 0;
                    width: 1px;
                    height: parent.height;
                    background: Theme.divider;
                }
            }

            // Main content
            Rectangle {
                horizontal-stretch: 1;
                VerticalLayout {
                    padding: 20px;
                    spacing: 20px;
                    // Header row
                    HorizontalLayout {
                        spacing: 8px;
                        alignment: stretch;
                        VerticalLayout {
                            alignment: center;
                            Text {
                                text: Theme.overview-title;
                                color: Theme.accent-soft;
                                font-size: 14px;
                            }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        ModePill { label: "AI"; active: true; }
                        ModePill { label: "GAME"; }
                        ModePill { label: "WORK"; }
                    }
                    // HUD row: gauge + meters
                    HorizontalLayout {
                        spacing: 26px;
                        alignment: stretch;
                        VerticalLayout {
                            alignment: center;
                            Gauge {
                                ratio: Sys.gpu-ratio;
                                value-text: Sys.gpu-text;
                                caption: "GPU LOAD";
                            }
                        }
                        VerticalLayout {
                            horizontal-stretch: 1;
                            alignment: center;
                            spacing: 14px;
                            Meter {
                                label: "VRAM";
                                value: Sys.vram-text;
                                ratio: Sys.vram-ratio;
                            }
                            Meter {
                                label: "RAM";
                                value: Sys.ram-text;
                                ratio: Sys.ram-ratio;
                            }
                            Meter {
                                label: "CPU";
                                value: Sys.cpu-text;
                                ratio: Sys.cpu-ratio;
                            }
                            Meter {
                                label: "GPU TEMP";
                                value: Sys.temp-text;
                                ratio: Sys.temp-ratio;
                                warn: Sys.temp-warn;
                            }
                        }
                    }
                    Rectangle { vertical-stretch: 1; }
                }
            }
        }

        // ── Status bar ─────────────────────────────────────────────
        Rectangle {
            height: 32px;
            Rectangle {
                x: 0;
                y: 0;
                width: parent.width;
                height: 1px;
                background: Theme.divider;
            }
            HorizontalLayout {
                padding-left: 20px;
                padding-right: 20px;
                Text {
                    text: Sys.gpu-available ? "BROKER CONNECTED · GPU LINKED" : "BROKER CONNECTED · NO GPU";
                    color: Theme.text-dim;
                    vertical-alignment: center;
                    font-size: 11px;
                }
                Rectangle { horizontal-stretch: 1; }
                HorizontalLayout {
                    spacing: 7px;
                    alignment: end;
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 6px;
                            height: 6px;
                            border-radius: 3px;
                            background: Theme.accent;
                        }
                    }
                    Text {
                        text: "NOMINAL";
                        color: Theme.accent-soft;
                        vertical-alignment: center;
                        font-size: 11px;
                    }
                }
            }
        }
    }
}
