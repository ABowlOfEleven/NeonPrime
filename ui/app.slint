// NeonPrime UI — P3: nav-driven views + the Tweaks panel.
// Themes via `Theme.hev`; live telemetry via `Sys`; tweak rows via `Tweaks`.

import { ListView } from "std-widgets.slint";

export global Theme {
    in-out property <bool> hev: false;

    out property <color> bg: hev ? #0d0b06 : #061119;
    out property <color> divider: hev ? #463209 : #123043;
    out property <color> track: hev ? #261b07 : #0e2230;

    out property <color> accent: hev ? #ff9f2e : #34d2ff;
    out property <color> accent-soft: hev ? #ffc061 : #8ae9ff;
    out property <color> ember: hev ? #e24b4a : #ce8a1f;
    out property <color> ember-soft: hev ? #ff7a6a : #e6ae45;

    out property <color> text-dim: hev ? #8a6a2a : #5c7e92;
    out property <color> text-body: hev ? #c9a766 : #a9c6d6;

    out property <string> overview-title: hev ? "HAZARD SYSTEMS ONLINE" : "SYSTEM OVERVIEW";
    out property <string> tweaks-label: hev ? "PRY BLOAT" : "TWEAKS";
    out property <string> tagline: hev ? "HEV · v3.0" : "v3.0.0";
    out property <string> toggle-label: hev ? "THEME: HEV" : "THEME: HOLO";
}

export global Sys {
    in-out property <float> cpu-ratio: 0;
    in-out property <string> cpu-text: "—";
    in-out property <float> cpu-temp-ratio: 0;
    in-out property <string> cpu-temp-text: "—";
    in-out property <bool> cpu-temp-warn: false;
    in-out property <string> gpu-name: "—";
    in-out property <float> ram-ratio: 0;
    in-out property <string> ram-text: "—";
    in-out property <bool> gpu-available: false;
    in-out property <float> gpu-ratio: 0;
    in-out property <string> gpu-text: "—";
    in-out property <float> vram-ratio: 0;
    in-out property <string> vram-text: "—";
    in-out property <float> temp-ratio: 0;
    in-out property <string> temp-text: "—";
    in-out property <bool> temp-warn: false;
    in-out property <string> spec-os: "—";
    in-out property <string> spec-cpu: "—";
    in-out property <string> spec-ram: "—";
    in-out property <string> spec-uptime: "—";
    // Rolling-history samples (0..1), newest last. Rendered as bar sparklines.
    in-out property <[float]> cpu-history;
    in-out property <[float]> gpu-history;
}

export global Power {
    in property <int> active-plan: -1; // index into the plan list, -1 = custom
    callback set-plan(int);
}

// Which page the sidebar has selected.
export global Nav {
    in-out property <int> page: 0;
    callback changed(int); // fired on navigation, so Rust can refresh that panel
}

export struct TweakRow {
    id: int,
    name: string,
    desc: string,
    category: string,
    applied: bool,
    elevated: bool,
}

export global Tweaks {
    in property <[TweakRow]> rows;
    in-out property <string> filter-text;
    in-out property <string> filter-cat: "ALL";
    // (row-id, desired-applied)
    callback toggle(int, bool);
    callback filter();
    callback apply-essential();
}

export struct AppRow {
    id: int,
    name: string,
    desc: string,
    category: string,
}

export global Installer {
    in property <[AppRow]> rows;
    in-out property <string> filter-text;
    in property <int> count;
    callback install(int);
    callback filter();
}

export struct ModeCard {
    id: int,
    name: string,
    tagline: string,
    desc: string,
}

export global Modes {
    in property <[ModeCard]> cards;
    in-out property <int> active: -1;
    callback activate(int);
}

export global Configuration {
    in-out property <string> preview;
    in-out property <string> status;
    callback export-config();
    callback import-config();
    callback run-fix(int);          // 0 repair, 1 network, 2 windows-update
    callback set-update-mode(int);  // 0 default, 1 security-only, 2 disabled
}

export global Ui {
    in-out property <string> toast-message;
    in-out property <string> toast-kind; // "error" | "success" | "info"
    callback toggle-theme();
    callback undo-last();
    callback enable-sensors();
}

export struct QuickRow {
    id: int,
    name: string,
    desc: string,
    danger: bool,
    elevated: bool,
}

export global Quick {
    in property <[QuickRow]> rows;
    callback run(int);
}

export struct StartupRow {
    id: int,
    name: string,
    command: string,
    enabled: bool,
}

export global Startup {
    in property <[StartupRow]> rows;
    callback toggle(int, bool);
}

export struct FeatureRow {
    id: int,
    name: string,
    desc: string,
}

export global Features {
    in property <[FeatureRow]> rows;
    callback apply(int, bool); // (id, enable)
}

export struct PrivacyCheck {
    id: int, // tweak catalog index
    name: string,
    desc: string,
    hardened: bool,
    elevated: bool,
}

export global Privacy {
    in property <[PrivacyCheck]> checks;
    in property <int> score; // 0..100
    in property <int> hardened-count;
    in property <int> total;
    callback harden(int);
    callback harden-all();
}

export struct CleanRow {
    id: int,
    name: string,
    desc: string,
    size: string,
    elevated: bool,
}

export global Cleanup {
    in property <[CleanRow]> rows;
    in property <bool> scanning: true;
    in property <string> total;
    callback clean(int);
    callback rescan();
}

export struct NetRow {
    proc-name: string,
    pid: int,
    remote: string,
    state: string,
}

export global Network {
    in property <[NetRow]> rows;
    in property <int> count;
    callback refresh();
}

export struct DebloatRow {
    id: int,
    name: string,
    desc: string,
    present: bool, // installed
    known: bool, // false until probed
}

export global Debloat {
    in property <[DebloatRow]> rows;
    in property <bool> probing: true;
    callback remove(int);
    callback disable-telemetry-tasks();
}

export struct HistoryRow {
    id: int, // journal entry id
    label: string,
    when: string, // pre-formatted relative time
    detail: string, // registry target summary
    active: bool,
    elevated: bool,
}

export global History {
    in property <[HistoryRow]> rows;
    in property <int> active-count;
    callback revert(int);
    callback revert-all();
}

component NavItem inherits Rectangle {
    in property <string> label;
    in property <int> index;
    in property <image> icon;
    property <bool> active: Nav.page == root.index;
    height: 31px;
    background: active ? Theme.accent.with-alpha(0.08) : transparent;

    Rectangle {
        x: 0;
        y: 0;
        width: 3px;
        height: parent.height;
        background: active ? Theme.accent : transparent;
    }
    HorizontalLayout {
        padding-left: 16px;
        spacing: 12px;
        alignment: start;
        VerticalLayout {
            alignment: center;
            Image {
                width: 20px;
                height: 20px;
                source: root.icon;
                colorize: active ? Theme.accent : Theme.text-dim;
            }
        }
        Text {
            text: root.label;
            color: active ? Theme.accent-soft : Theme.text-dim;
            vertical-alignment: center;
            font-size: 12px;
        }
    }
    TouchArea {
        clicked => {
            Nav.page = root.index;
            Nav.changed(root.index);
        }
    }
}

// A dim caption that groups the nav items beneath it.
component NavSection inherits Rectangle {
    in property <string> label;
    height: 22px;
    Text {
        x: 18px;
        y: parent.height - self.height - 2px;
        text: root.label;
        color: Theme.text-dim.with-alpha(0.7);
        font-size: 9px;
        letter-spacing: 1px;
    }
}

component ModePill inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked;
    width: 58px;
    height: 26px;
    border-radius: 8px;
    border-width: 1px;
    border-color: active ? Theme.accent : Theme.divider;
    background: active ? Theme.accent.with-alpha(0.16) : transparent;
    Text {
        text: root.label;
        color: active ? Theme.accent-soft : Theme.text-dim;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 11px;
    }
    TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component Meter inherits VerticalLayout {
    in property <string> label;
    in property <string> value;
    in property <float> ratio;
    in property <bool> warn;
    spacing: 6px;

    HorizontalLayout {
        Text {
            text: root.label;
            color: Theme.text-dim;
            font-size: 11px;
        }
        Rectangle { horizontal-stretch: 1; }
        Text {
            text: root.value;
            color: root.warn ? Theme.ember-soft : Theme.accent;
            font-size: 11px;
        }
    }
    Rectangle {
        height: 10px;
        border-radius: 5px;
        background: Theme.track;
        Rectangle {
            x: 0;
            y: 0;
            width: parent.width * clamp(root.ratio, 0, 1);
            height: parent.height;
            border-radius: 5px;
            background: root.warn ? Theme.ember : Theme.accent;
        }
    }
}

component Gauge inherits Rectangle {
    in property <float> ratio;
    in property <string> value-text;
    in property <string> caption;
    in property <bool> warn;
    width: 132px;
    height: 132px;

    property <float> r: clamp(root.ratio, 0, 0.9999);
    property <angle> end-ang: -90deg + r * 359.9deg;
    property <float> ex: 62 + 58 * cos(end-ang);
    property <float> ey: 62 + 58 * sin(end-ang);
    property <int> large: r * 359.9 > 180 ? 1 : 0;

    Rectangle {
        x: 4px;
        y: 4px;
        width: 124px;
        height: 124px;
        border-radius: 62px;
        border-width: 8px;
        border-color: Theme.track;
        background: transparent;
    }
    Path {
        x: 4px;
        y: 4px;
        width: 124px;
        height: 124px;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: 124;
        viewbox-height: 124;
        commands: "M 62 4 A 58 58 0 \{root.large} 1 \{root.ex} \{root.ey}";
        stroke: root.warn ? Theme.ember : Theme.accent;
        stroke-width: 7px;
        fill: transparent;
    }
    VerticalLayout {
        alignment: center;
        spacing: 2px;
        Text {
            text: root.value-text;
            color: root.warn ? Theme.ember-soft : Theme.accent-soft;
            horizontal-alignment: center;
            font-size: 30px;
        }
        Text {
            text: root.caption;
            color: Theme.text-dim;
            horizontal-alignment: center;
            font-size: 11px;
        }
    }
}

component Sparkline inherits Rectangle {
    in property <[float]> values;
    in property <color> tint;
    in property <string> label;
    in property <string> value;
    height: 46px;
    HorizontalLayout {
        spacing: 12px;
        VerticalLayout {
            width: 76px;
            alignment: center;
            spacing: 2px;
            Text {
                text: root.label;
                color: Theme.text-dim;
                font-size: 10px;
            }
            Text {
                text: root.value;
                color: root.tint;
                font-size: 14px;
            }
        }
        // Bar histogram — fills the full width via layout, newest on the right.
        Rectangle {
            horizontal-stretch: 1;
            clip: true;
            Rectangle {
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: Theme.divider;
            }
            HorizontalLayout {
                spacing: 1px;
                for v in root.values: Rectangle {
                    bar := Rectangle {
                        width: parent.width;
                        height: max(1px, parent.height * clamp(v, 0, 1));
                        y: parent.height - self.height;
                        border-radius: 1px;
                        background: root.tint.with-alpha(0.85);
                    }
                }
            }
        }
    }
}

component Toggle inherits Rectangle {
    in property <bool> on;
    callback toggled(bool);
    width: 44px;
    height: 22px;
    border-radius: 11px;
    border-width: 1px;
    border-color: on ? Theme.accent : Theme.divider;
    background: on ? Theme.accent.with-alpha(0.2) : transparent;

    Rectangle {
        width: 16px;
        height: 16px;
        border-radius: 8px;
        y: 3px;
        x: on ? parent.width - 19px : 3px;
        background: on ? Theme.accent : Theme.text-dim;
        animate x { duration: 110ms; easing: ease-out; }
    }
    TouchArea {
        clicked => {
            root.toggled(!root.on);
        }
    }
}

component PushButton inherits Rectangle {
    in property <string> label;
    in property <length> w: 78px;
    in property <bool> danger: false;
    property <color> tint: danger ? Theme.ember : Theme.accent;
    property <color> tint-soft: danger ? Theme.ember-soft : Theme.accent-soft;
    callback clicked;
    width: root.w;
    height: 26px;
    border-radius: 7px;
    border-width: 1px;
    border-color: tint;
    background: touch.pressed ? tint.with-alpha(0.28) : tint.with-alpha(0.12);
    Text {
        text: root.label;
        color: tint-soft;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 11px;
    }
    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component QuickActionRow inherits Rectangle {
    in property <QuickRow> qa;
    height: 56px;
    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        spacing: 14px;
        VerticalLayout {
            alignment: center;
            spacing: 3px;
            horizontal-stretch: 1;
            HorizontalLayout {
                spacing: 8px;
                alignment: start;
                Text {
                    text: root.qa.name;
                    color: Theme.text-body;
                    font-size: 13px;
                    vertical-alignment: center;
                }
                if root.qa.elevated: Text {
                    text: "· ADMIN";
                    color: Theme.ember-soft;
                    font-size: 9px;
                    vertical-alignment: center;
                }
            }
            Text {
                text: root.qa.desc;
                color: Theme.text-dim;
                font-size: 11px;
                wrap: word-wrap;
            }
        }
        VerticalLayout {
            alignment: center;
            PushButton {
                label: "RUN";
                danger: root.qa.danger;
                clicked => {
                    Quick.run(root.qa.id);
                }
            }
        }
    }
    Rectangle {
        x: 0;
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.divider;
    }
}

// Shared panel header: title (left), dim hint + any action buttons (right).
component PanelHeader inherits HorizontalLayout {
    in property <string> title;
    in property <string> hint: "";
    height: 30px;
    padding-left: 20px;
    padding-right: 20px;
    spacing: 10px;
    VerticalLayout {
        alignment: center;
        Text {
            text: root.title;
            color: Theme.accent-soft;
            font-size: 14px;
        }
    }
    Rectangle { horizontal-stretch: 1; }
    VerticalLayout {
        alignment: center;
        Text {
            text: root.hint;
            color: Theme.text-dim;
            font-size: 11px;
            horizontal-alignment: right;
        }
    }
    @children
}

// Centered placeholder for empty / loading lists.
component EmptyState inherits VerticalLayout {
    in property <string> text;
    alignment: center;
    Text {
        text: root.text;
        color: Theme.text-dim;
        font-size: 12px;
        horizontal-alignment: center;
        wrap: word-wrap;
    }
}

component QuickActionsView inherits VerticalLayout {
    padding-top: 18px;
    padding-bottom: 8px;
    spacing: 12px;
    PanelHeader { title: "QUICK ACTIONS"; hint: "one-click maintenance"; }
    ListView {
        vertical-stretch: 1;
        for a in Quick.rows: QuickActionRow {
            qa: a;
        }
    }
}

component AppRowView inherits Rectangle {
    in property <AppRow> app;
    height: 54px;
    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        spacing: 14px;
        VerticalLayout {
            alignment: center;
            spacing: 3px;
            horizontal-stretch: 1;
            HorizontalLayout {
                spacing: 8px;
                alignment: start;
                Text {
                    text: root.app.name;
                    color: Theme.text-body;
                    font-size: 13px;
                    vertical-alignment: center;
                }
                Text {
                    text: root.app.category;
                    color: Theme.text-dim;
                    font-size: 9px;
                    vertical-alignment: center;
                }
            }
            Text {
                text: root.app.desc;
                color: Theme.text-dim;
                font-size: 11px;
                overflow: elide;
            }
        }
        VerticalLayout {
            alignment: center;
            PushButton {
                label: "INSTALL";
                clicked => {
                    Installer.install(root.app.id);
                }
            }
        }
    }
    Rectangle {
        x: 0;
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.divider;
    }
}

component InstallView inherits VerticalLayout {
    padding-top: 18px;
    padding-bottom: 8px;
    spacing: 10px;
    PanelHeader { title: "INSTALL"; hint: "\{Installer.count} apps · winget"; }
    HorizontalLayout {
        padding-left: 20px;
        padding-right: 20px;
        Rectangle {
            height: 30px;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.divider;
            background: Theme.track;
            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                TextInput {
                    text <=> Installer.filter-text;
                    color: Theme.text-body;
                    font-size: 12px;
                    vertical-alignment: center;
                    single-line: true;
                    edited => {
                        Installer.filter();
                    }
                }
            }
            if Installer.filter-text == "": Text {
                x: 11px;
                text: "search apps…";
                color: Theme.text-dim;
                font-size: 12px;
                vertical-alignment: center;
            }
        }
    }
    if Installer.rows.length == 0: EmptyState {
        vertical-stretch: 1;
        text: "No apps match your search.";
    }
    if Installer.rows.length > 0: ListView {
        vertical-stretch: 1;
        for a in Installer.rows: AppRowView {
            app: a;
        }
    }
}

component ModeCardView inherits Rectangle {
    in property <ModeCard> card;
    in property <bool> active;
    callback activate;
    height: 96px;
    border-radius: 12px;
    border-width: active ? 2px : 1px;
    border-color: active ? Theme.accent : Theme.divider;
    background: active ? Theme.accent.with-alpha(0.08) : transparent;
    HorizontalLayout {
        padding: 16px;
        spacing: 14px;
        VerticalLayout {
            alignment: center;
            spacing: 4px;
            horizontal-stretch: 1;
            HorizontalLayout {
                spacing: 8px;
                alignment: start;
                Text {
                    text: root.card.name;
                    color: Theme.accent-soft;
                    font-size: 15px;
                    vertical-alignment: center;
                }
                if root.active: Text {
                    text: "● ACTIVE";
                    color: Theme.accent;
                    font-size: 10px;
                    vertical-alignment: center;
                }
            }
            Text {
                text: root.card.tagline;
                color: Theme.text-body;
                font-size: 12px;
            }
            Text {
                text: root.card.desc;
                color: Theme.text-dim;
                font-size: 11px;
                wrap: word-wrap;
            }
        }
        VerticalLayout {
            alignment: center;
            PushButton {
                label: root.active ? "ACTIVE" : "ACTIVATE";
                clicked => {
                    root.activate();
                }
            }
        }
    }
}

component ModesView inherits VerticalLayout {
    padding: 20px;
    spacing: 14px;
    Text {
        text: Theme.hev ? "OPERATING MODES" : "SYSTEM MODES";
        color: Theme.accent-soft;
        font-size: 14px;
    }
    for card[i] in Modes.cards: ModeCardView {
        card: card;
        active: Modes.active == i;
        activate => {
            Modes.activate(i);
        }
    }
    Rectangle { height: 1px; background: Theme.divider; }
    HorizontalLayout {
        spacing: 10px;
        VerticalLayout {
            alignment: center;
            Text {
                text: "POWER PLAN";
                color: Theme.accent-soft;
                font-size: 13px;
            }
        }
        Rectangle { width: 8px; }
        ModePill { label: "BALANCED"; active: Power.active-plan == 0; clicked => { Power.set-plan(0); } }
        ModePill { label: "HIGH PERF"; active: Power.active-plan == 1; clicked => { Power.set-plan(1); } }
        ModePill { label: "ULTIMATE"; active: Power.active-plan == 2; clicked => { Power.set-plan(2); } }
        Rectangle { horizontal-stretch: 1; }
    }
    Rectangle { vertical-stretch: 1; }
}

component TweakRowView inherits Rectangle {
    in property <TweakRow> tw;
    height: 60px;

    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        spacing: 14px;
        VerticalLayout {
            alignment: center;
            spacing: 4px;
            horizontal-stretch: 1;
            HorizontalLayout {
                spacing: 8px;
                alignment: start;
                Text {
                    text: root.tw.name;
                    color: Theme.text-body;
                    font-size: 13px;
                    vertical-alignment: center;
                }
                Text {
                    text: root.tw.category;
                    color: Theme.text-dim;
                    font-size: 9px;
                    vertical-alignment: center;
                }
                if root.tw.elevated: Text {
                    text: "· ADMIN";
                    color: Theme.ember-soft;
                    font-size: 9px;
                    vertical-alignment: center;
                }
            }
            Text {
                text: root.tw.desc;
                color: Theme.text-dim;
                font-size: 11px;
                wrap: word-wrap;
            }
        }
        VerticalLayout {
            alignment: center;
            Toggle {
                on: root.tw.applied;
                toggled(v) => {
                    Tweaks.toggle(root.tw.id, v);
                }
            }
        }
    }
    Rectangle {
        x: 0;
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.divider;
    }
}

component SpecRow inherits HorizontalLayout {
    in property <string> label;
    in property <string> value;
    spacing: 10px;
    Text {
        text: root.label;
        color: Theme.text-dim;
        font-size: 11px;
        width: 64px;
        vertical-alignment: center;
    }
    Text {
        text: root.value;
        color: Theme.text-body;
        font-size: 11px;
        horizontal-stretch: 1;
        vertical-alignment: center;
        overflow: elide;
    }
}

component DashboardView inherits VerticalLayout {
    padding: 20px;
    spacing: 20px;
    HorizontalLayout {
        spacing: 8px;
        alignment: stretch;
        VerticalLayout {
            alignment: center;
            Text {
                text: Theme.overview-title;
                color: Theme.accent-soft;
                font-size: 14px;
            }
        }
        Rectangle { horizontal-stretch: 1; }
        ModePill { label: "AI"; active: Modes.active == 0; clicked => { Modes.activate(0); } }
        ModePill { label: "GAME"; active: Modes.active == 1; clicked => { Modes.activate(1); } }
        ModePill { label: "WORK"; active: Modes.active == 2; clicked => { Modes.activate(2); } }
    }
    HorizontalLayout {
        spacing: 26px;
        alignment: stretch;
        VerticalLayout {
            alignment: center;
            Gauge {
                ratio: Sys.gpu-ratio;
                value-text: Sys.gpu-text;
                caption: "GPU LOAD";
            }
        }
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 14px;
            Meter { label: "VRAM"; value: Sys.vram-text; ratio: Sys.vram-ratio; }
            Meter { label: "RAM"; value: Sys.ram-text; ratio: Sys.ram-ratio; }
            Meter { label: "CPU"; value: Sys.cpu-text; ratio: Sys.cpu-ratio; }
            Meter { label: "CPU TEMP"; value: Sys.cpu-temp-text; ratio: Sys.cpu-temp-ratio; warn: Sys.cpu-temp-warn; }
            Meter { label: "GPU TEMP"; value: Sys.temp-text; ratio: Sys.temp-ratio; warn: Sys.temp-warn; }
        }
    }
    // Live history sparklines
    Rectangle {
        border-radius: 10px;
        border-width: 1px;
        border-color: Theme.divider;
        background: Theme.track;
        VerticalLayout {
            padding: 12px;
            spacing: 8px;
            Sparkline {
                label: "CPU";
                value: Sys.cpu-text;
                tint: Theme.accent;
                values: Sys.cpu-history;
            }
            Sparkline {
                label: "GPU";
                value: Sys.gpu-text;
                tint: Theme.ember;
                values: Sys.gpu-history;
            }
        }
    }
    // System specs strip
    Rectangle {
        vertical-stretch: 1;
        border-radius: 10px;
        border-width: 1px;
        border-color: Theme.divider;
        background: Theme.track;
        VerticalLayout {
            padding: 14px;
            spacing: 7px;
            alignment: start;
            SpecRow { label: "OS"; value: Sys.spec-os; }
            SpecRow { label: "CPU"; value: Sys.spec-cpu; }
            SpecRow { label: "GPU"; value: Sys.gpu-name; }
            SpecRow { label: "RAM"; value: Sys.spec-ram; }
            SpecRow { label: "UPTIME"; value: Sys.spec-uptime; }
            Rectangle { vertical-stretch: 1; }
            HorizontalLayout {
                Rectangle { horizontal-stretch: 1; }
                PushButton {
                    w: 184px;
                    label: "ENABLE HW SENSORS (admin)";
                    clicked => {
                        Ui.enable-sensors();
                    }
                }
            }
        }
    }
}

component FilterChip inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked;
    height: 24px;
    width: chip-txt.preferred-width + 18px;
    border-radius: 6px;
    border-width: 1px;
    border-color: active ? Theme.accent : Theme.divider;
    background: active ? Theme.accent.with-alpha(0.16) : transparent;
    chip-txt := Text {
        x: 9px;
        text: root.label;
        color: active ? Theme.accent-soft : Theme.text-dim;
        vertical-alignment: center;
        font-size: 10px;
    }
    TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component TweaksView inherits VerticalLayout {
    padding-top: 18px;
    padding-bottom: 8px;
    spacing: 10px;
    PanelHeader {
        title: Theme.hev ? "PRY THE BLOAT" : "TWEAKS";
        PushButton {
            w: 104px;
            label: "ESSENTIALS";
            clicked => {
                Tweaks.apply-essential();
            }
        }
        PushButton {
            w: 96px;
            label: "UNDO LAST";
            clicked => {
                Ui.undo-last();
            }
        }
    }
    // Search box
    HorizontalLayout {
        padding-left: 20px;
        padding-right: 20px;
        Rectangle {
            height: 30px;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.divider;
            background: Theme.track;
            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                TextInput {
                    text <=> Tweaks.filter-text;
                    color: Theme.text-body;
                    font-size: 12px;
                    vertical-alignment: center;
                    single-line: true;
                    edited => {
                        Tweaks.filter();
                    }
                }
            }
            if Tweaks.filter-text == "": Text {
                x: 11px;
                text: "search tweaks…";
                color: Theme.text-dim;
                font-size: 12px;
                vertical-alignment: center;
            }
        }
    }
    // Category chips
    HorizontalLayout {
        padding-left: 20px;
        padding-right: 20px;
        spacing: 7px;
        alignment: start;
        FilterChip { label: "ALL"; active: Tweaks.filter-cat == "ALL"; clicked => { Tweaks.filter-cat = "ALL"; Tweaks.filter(); } }
        FilterChip { label: "UI"; active: Tweaks.filter-cat == "INTERFACE"; clicked => { Tweaks.filter-cat = "INTERFACE"; Tweaks.filter(); } }
        FilterChip { label: "PRIVACY"; active: Tweaks.filter-cat == "PRIVACY"; clicked => { Tweaks.filter-cat = "PRIVACY"; Tweaks.filter(); } }
        FilterChip { label: "PERF"; active: Tweaks.filter-cat == "PERFORMANCE"; clicked => { Tweaks.filter-cat = "PERFORMANCE"; Tweaks.filter(); } }
        FilterChip { label: "SANDBOX"; active: Tweaks.filter-cat == "SANDBOX"; clicked => { Tweaks.filter-cat = "SANDBOX"; Tweaks.filter(); } }
        Rectangle { horizontal-stretch: 1; }
    }
    if Tweaks.rows.length == 0: EmptyState {
        vertical-stretch: 1;
        text: "No tweaks match your search.";
    }
    if Tweaks.rows.length > 0: ListView {
        vertical-stretch: 1;
        for row in Tweaks.rows: TweakRowView {
            tw: row;
        }
    }
}

component ConfigView inherits VerticalLayout {
    property <int> tab: 0;
    padding-top: 18px;
    padding-bottom: 8px;
    spacing: 12px;
    PanelHeader { title: "CONFIG"; hint: "backup · repair · updates"; }
    // Sub-tabs
    HorizontalLayout {
        padding-left: 20px;
        padding-right: 20px;
        spacing: 7px;
        alignment: start;
        FilterChip { label: "BACKUP"; active: root.tab == 0; clicked => { root.tab = 0; } }
        FilterChip { label: "FIXES"; active: root.tab == 1; clicked => { root.tab = 1; } }
        FilterChip { label: "UPDATES"; active: root.tab == 2; clicked => { root.tab = 2; } }
        Rectangle { horizontal-stretch: 1; }
    }

    // ── BACKUP ──────────────────────────────────────────────────
    if root.tab == 0: VerticalLayout {
        vertical-stretch: 1;
        padding-left: 20px;
        padding-right: 20px;
        spacing: 12px;
        Text {
            text: "Capture your tuned setup to a portable TOML file, and replay it on a fresh install.";
            color: Theme.text-dim;
            font-size: 12px;
            wrap: word-wrap;
        }
        HorizontalLayout {
            spacing: 12px;
            alignment: start;
            PushButton {
                label: "EXPORT";
                clicked => { Configuration.export-config(); }
            }
            PushButton {
                w: 128px;
                label: "IMPORT & APPLY";
                clicked => { Configuration.import-config(); }
            }
        }
        Text {
            text: Configuration.status;
            color: Theme.ember-soft;
            font-size: 11px;
            wrap: word-wrap;
        }
        Rectangle {
            vertical-stretch: 1;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.divider;
            background: Theme.track;
            VerticalLayout {
                padding: 12px;
                Text {
                    text: Configuration.preview == "" ? "// Click EXPORT to snapshot your current tweaks + active mode." : Configuration.preview;
                    color: Theme.text-body;
                    font-size: 11px;
                    wrap: word-wrap;
                }
                Rectangle { vertical-stretch: 1; }
            }
        }
    }

    // ── FIXES ───────────────────────────────────────────────────
    if root.tab == 1: VerticalLayout {
        vertical-stretch: 1;
        padding-left: 20px;
        padding-right: 20px;
        spacing: 12px;
        Text {
            text: "Elevated repairs — each opens a console and asks for admin (UAC).";
            color: Theme.text-dim;
            font-size: 12px;
            wrap: word-wrap;
        }
        HorizontalLayout {
            spacing: 10px;
            alignment: start;
            PushButton { w: 132px; label: "REPAIR SYSTEM"; clicked => { Configuration.run-fix(0); } }
            PushButton { w: 128px; label: "RESET NETWORK"; clicked => { Configuration.run-fix(1); } }
            PushButton { w: 160px; label: "RESET WIN UPDATE"; clicked => { Configuration.run-fix(2); } }
        }
        Rectangle { vertical-stretch: 1; }
    }

    // ── UPDATES ─────────────────────────────────────────────────
    if root.tab == 2: VerticalLayout {
        vertical-stretch: 1;
        padding-left: 20px;
        padding-right: 20px;
        spacing: 12px;
        Text {
            text: "Choose how updates behave. DEFAULT clears the policy and undoes the others.";
            color: Theme.text-dim;
            font-size: 12px;
            wrap: word-wrap;
        }
        HorizontalLayout {
            spacing: 10px;
            alignment: start;
            PushButton { w: 96px; label: "DEFAULT"; clicked => { Configuration.set-update-mode(0); } }
            PushButton { w: 124px; label: "SECURITY ONLY"; clicked => { Configuration.set-update-mode(1); } }
            PushButton { w: 100px; danger: true; label: "DISABLED"; clicked => { Configuration.set-update-mode(2); } }
        }
        Rectangle { vertical-stretch: 1; }
    }
}

component StartupRowView inherits Rectangle {
    in property <StartupRow> entry;
    height: 52px;
    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        spacing: 14px;
        VerticalLayout {
            alignment: center;
            spacing: 3px;
            horizontal-stretch: 1;
            Text {
                text: root.entry.name;
                color: Theme.text-body;
                font-size: 13px;
                overflow: elide;
            }
            Text {
                text: root.entry.command;
                color: Theme.text-dim;
                font-size: 10px;
                overflow: elide;
            }
        }
        VerticalLayout {
            alignment: center;
            Toggle {
                on: root.entry.enabled;
                toggled(v) => {
                    Startup.toggle(root.entry.id, v);
                }
            }
        }
    }
    Rectangle {
        x: 0;
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.divider;
    }
}

component StartupView inherits VerticalLayout {
    padding-top: 18px;
    padding-bottom: 8px;
