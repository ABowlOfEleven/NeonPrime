        }
    }
}

component Toast inherits Rectangle {
    in property <string> message;
    in property <string> kind;
    property <color> tint: kind == "error" ? Theme.ember : Theme.accent;
    property <color> tint-soft: kind == "error" ? Theme.ember-soft : Theme.accent-soft;
    visible: message != "";
    height: 38px;
    border-radius: 8px;
    border-width: 1px;
    border-color: tint;
    background: Theme.track;
    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 10px;
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 7px;
                height: 7px;
                border-radius: 4px;
                background: tint;
            }
        }
        Text {
            text: root.message;
            color: tint-soft;
            vertical-alignment: center;
            font-size: 12px;
            overflow: elide;
        }
    }
}

export component AppWindow inherits Window {
    title: "NeonPrime";
    default-font-size: 13px;
    preferred-width: 760px;
    preferred-height: 640px;
    min-width: 640px;
    min-height: 600px;
    background: Theme.bg;

    VerticalLayout {
        // ── Title bar ──────────────────────────────────────────────
        Rectangle {
            height: 44px;
            HorizontalLayout {
                padding-left: 20px;
                padding-right: 14px;
                spacing: 12px;
                alignment: start;
                VerticalLayout {
                    alignment: center;
                    Image {
                        width: 20px;
                        height: 20px;
                        source: Theme.hev ? @image-url("icons/lambda.svg") : @image-url("icons/logo.svg");
                        colorize: Theme.accent-soft;
                    }
                }
                VerticalLayout {
                    alignment: center;
                    Text {
                        text: "NEONPRIME";
                        color: Theme.accent-soft;
                        font-size: 16px;
                    }
                }
                VerticalLayout {
                    alignment: center;
                    Text {
                        text: Theme.tagline;
                        color: Theme.text-dim;
                        font-size: 11px;
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                Rectangle {
                    width: 112px;
                    height: 26px;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: Theme.divider;
                    background: Theme.accent.with-alpha(0.08);
                    Text {
                        text: Theme.toggle-label;
                        color: Theme.accent-soft;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: 11px;
                    }
                    TouchArea {
                        clicked => {
                            Ui.toggle-theme();
                        }
                    }
                }
            }
            Rectangle {
                x: 0;
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: Theme.divider;
            }
        }

        // ── Body ───────────────────────────────────────────────────
        HorizontalLayout {
            Rectangle {
                width: 160px;
                VerticalLayout {
                    padding-top: 14px;
                    padding-bottom: 14px;
                    spacing: 2px;
                    NavItem { label: "DASHBOARD"; index: 0; icon: @image-url("icons/dashboard.svg"); }
                    NavItem { label: "NETWORK"; index: 11; icon: @image-url("icons/network.svg"); }

                    NavSection { label: "OPTIMIZE"; }
                    NavItem { label: Theme.tweaks-label; index: 1; icon: Theme.hev ? @image-url("icons/crowbar.svg") : @image-url("icons/tweaks.svg"); }
                    NavItem { label: "PRIVACY"; index: 8; icon: @image-url("icons/shield.svg"); }
                    NavItem { label: "DEBLOAT"; index: 10; icon: @image-url("icons/debloat.svg"); }
                    NavItem { label: "CLEANUP"; index: 12; icon: @image-url("icons/cleanup.svg"); }
                    NavItem { label: "STARTUP"; index: 6; icon: @image-url("icons/power.svg"); }

                    NavSection { label: "SOFTWARE"; }
                    NavItem { label: "INSTALL"; index: 2; icon: @image-url("icons/install.svg"); }
                    NavItem { label: "FEATURES"; index: 7; icon: @image-url("icons/features.svg"); }

                    NavSection { label: "SYSTEM"; }
                    NavItem { label: "MODES"; index: 3; icon: @image-url("icons/modes.svg"); }
                    NavItem { label: "ACTIONS"; index: 5; icon: @image-url("icons/bolt.svg"); }
                    NavItem { label: "CONFIG"; index: 4; icon: @image-url("icons/config.svg"); }
                    NavItem { label: "HISTORY"; index: 9; icon: @image-url("icons/history.svg"); }
                    Rectangle { vertical-stretch: 1; }
                    HorizontalLayout {
                        padding-left: 18px;
                        spacing: 10px;
                        alignment: start;
                        Rectangle {
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            background: Theme.accent;
                        }
                        Text {
                            text: "BROKER · linked";
                            color: Theme.text-dim;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                    }
                }
                Rectangle {
                    x: parent.width - 1px;
                    y: 0;
                    width: 1px;
                    height: parent.height;
                    background: Theme.divider;
                }
            }

            // Main content — switches on Nav.page.
            Rectangle {
                horizontal-stretch: 1;
                if Nav.page == 0: DashboardView {
                    width: parent.width;
                    height: parent.height;
                }
                if Nav.page == 1: TweaksView {
                    width: parent.width;
                    height: parent.height;
                }
                if Nav.page == 2: InstallView {
                    width: parent.width;
                    height: parent.height;
                }
                if Nav.page == 3: ModesView {
                    width: parent.width;
                    height: parent.height;
                }
                if Nav.page == 4: ConfigView {
                    width: parent.width;
                    height: parent.height;
                }
                if Nav.page == 5: QuickActionsView {
                    width: parent.width;
                    height: parent.height;
                }
                if Nav.page == 6: StartupView {
                    width: parent.width;
                    height: parent.height;
                }
                if Nav.page == 7: FeaturesView {
                    width: parent.width;
                    height: parent.height;
                }
                if Nav.page == 8: PrivacyView {
                    width: parent.width;
                    height: parent.height;
                }
                if Nav.page == 9: HistoryView {
                    width: parent.width;
                    height: parent.height;
                }
                if Nav.page == 10: DebloatView {
                    width: parent.width;
                    height: parent.height;
                }
                if Nav.page == 11: NetworkView {
                    width: parent.width;
                    height: parent.height;
                }
                if Nav.page == 12: CleanupView {
                    width: parent.width;
                    height: parent.height;
                }

                Toast {
                    message: Ui.toast-message;
                    kind: Ui.toast-kind;
                    x: 16px;
                    width: parent.width - 32px;
                    y: parent.height - self.height - 14px;
                }
            }
        }

        // ── Status bar ─────────────────────────────────────────────
        Rectangle {
            height: 32px;
            Rectangle {
                x: 0;
                y: 0;
                width: parent.width;
                height: 1px;
                background: Theme.divider;
            }
            HorizontalLayout {
                padding-left: 20px;
                padding-right: 20px;
                Text {
                    text: Sys.gpu-available ? "BROKER CONNECTED · GPU LINKED" : "BROKER CONNECTED · NO GPU";
                    color: Theme.text-dim;
                    vertical-alignment: center;
                    font-size: 11px;
                }
                Rectangle { horizontal-stretch: 1; }
                HorizontalLayout {
                    spacing: 7px;
                    alignment: end;
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 6px;
                            height: 6px;
                            border-radius: 3px;
                            background: Theme.accent;
                        }
                    }
                    Text {
                        text: "NOMINAL";
                        color: Theme.accent-soft;
                        vertical-alignment: center;
                        font-size: 11px;
                    }
                }
            }
        }
    }
}
